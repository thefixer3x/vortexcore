# Rename this file to `.env` (gitignored) when copying the template into a project.
#
# Lingo.dev API key — get from https://lingo.dev → Account → API Keys.
# Preferred: store at ~/.lingodotdevrc via:
#   npx lingo.dev@latest config set auth.apiKey lingo_sk_xxx
# Fallback: set this env var. LINGODOTDEV_API_KEY is deprecated — use LINGO_API_KEY.
LINGO_API_KEY=lingo_sk_REPLACE_ME
