{
  "name": "vortexcore",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun --hot serve --port=5173 index.html",
    "build": "bun vite build",
    "build:dev": "bun vite build --mode development",
    "lint": "bun eslint .",
    "preview": "bun vite preview",
    "test:ai": "tsx src/test-ai.ts",
    "test": "vitest run",
    "test:components": "vitest --run src/test/__tests__/components",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:smoke": "bun smoke-test.js",
    "i18n:validate": "node scripts/validate-translations.js",
    "i18n:translate": "npx lingo.dev@latest i18n",
    "i18n:coverage": "cd ../.. && bun run i18n:coverage",
    "i18n:quality": "cd ../.. && bun run i18n:quality",
    "i18n": "npx lingo.dev@latest i18n",
    "i18n:check": "test -f locales/es.json && echo '✅ Translations exist' || echo '❌ Missing translations'"
  },
